{
  "version": "1.1.0",
  "description": "物华弥新全局逻辑注册中心 - 已更新 B 站攻略组精准伤害模型",
  
  "ACTION_CATEGORIES": {
    "DIRECT_ATTACK": ["NORMAL_ATTACK", "CLASS_SKILL", "ULTIMATE_SKILL"],
    "REACTIONARY_ATTACK": ["PURSUIT", "COUNTER", "ADDITIONAL_ATTACK", "COMBO"],
    "INDIRECT_DAMAGE": ["DOT", "EXTRA_DAMAGE", "STATUS_SETTLEMENT", "REAL_DAMAGE"]
  },

  "DAMAGE_ENGINE_V2": {
    "CONSTANTS": {
      "LEVEL_SCALING_FACTOR": 3,
      "LEVEL_BASE_OFFSET": 400,
      "BASE_THROUGH_STRENGTH": 0.7
    },
    "CALCULATION_STEPS": [
      {
        "step": "REAL_TIME_DEFENSE",
        "formula": "Original_Def * (1 - Def_Lowered - Ignore_Def) * (1 - Through_Strength)"
      },
      {
        "step": "DEFENSIVE_INTERVAL",
        "formula": "1 - (RealTime_Def / (RealTime_Def + Target_Level * 3 + 400)) * (1 - Def_Penetration)"
      },
      {
        "step": "TOTAL_DAMAGE",
        "multipliers": [
          "Attribute",
          "Magnification",
          "Crit_Multiplier",
          "All_Dmg_Inc",
          "Elem_Dmg_Inc",
          "Type_Dmg_Inc",
          "Special_Inc",
          "Vulnerability_Factor",
          "Defensive_Interval"
        ]
      }
    ]
  },

  "EVENT_BUS": {
    "DIRECT_ATTACK_DEALT": {
      "desc": "直接攻击造成伤害后",
      "alias": ["直接攻击造成的伤害后", "进行直接攻击后"],
      "note": "触发源必须是常击、职业技能或绝技。不包含追击、反击、持续伤害等。"
    },
    "ANY_UNIT_TURN_END": {
      "desc": "场上任意单位回合结束时",
      "alias": ["任意单位的回合结束时", "单位回合结束时"],
      "note": "包含敌我双方、召唤物。这是金乌礼弹回填的关键时点。"
    },
    "PURSUIT_ATTACK_DEALT": {
      "desc": "追击造成伤害后",
      "alias": ["进行追击造成的伤害后", "追击后"],
      "note": "特定触发：仅限标识为'追击'的行为。"
    },
    "ADDITIONAL_ATTACK_DEALT": {
      "desc": "追加攻击造成伤害后",
      "alias": ["造成追加攻击后"],
      "note": "酒帐的核心机制，注意与'追击'区分。"
    },
    "STATUS_EXIT": {
      "desc": "状态消失/结束时",
      "alias": ["状态结束时", "状态清除时"],
      "note": "用于触发清理逻辑，如四季同鸣结束清理灿金。"
    },
    "BATTLE_START": {
      "desc": "战斗开始时",
      "alias": ["进入战斗后", "战斗开始"],
      "note": "用于初始化团队 Buff 扫描。"
    },
    "SUMMON_CREATED": {
      "desc": "召唤物生成/入场时",
      "alias": ["召唤..."],
      "note": "产生一个新实体 ID 并绑定母体。"
    },
    "SUMMON_DEFEATED": {
      "desc": "召唤物被击败/离场时",
      "alias": ["任意召唤物被击败后"],
      "note": "用于触发母体的回能或状态刷新。"
    },
    "FATAL_HIT_RECEIVED": {
      "desc": "受到致命伤害时",
      "alias": ["受到致命伤害后"],
      "note": "关键时序：在死亡结算前触发，用于免死、不屈逻辑。"
    }
  },
  "GLOBAL_CONSTRAINTS": {
    "PREVENT_INFINITE_LOOP": true,
    "PURSUIT_TRIGGER_PURSUIT": false
  }
}
