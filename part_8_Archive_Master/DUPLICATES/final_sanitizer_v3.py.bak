# -*- coding: utf-8 -*-
import os, re, glob, html

def deep_sanitize_v3(raw_text, name):
    # 1. 精准切割
    start_pattern = f"![{name}.png]"
    end_pattern = '<table><tbody><tr><th colspan="3">考核<'
    
    start_idx = raw_text.find(start_pattern)
    if start_idx == -1:
        # 回退方案：找第一个“稀有度”
        start_idx = raw_text.find("稀有度")
    else:
        # 跳过图片标签行
        start_idx = raw_text.find('\n', start_idx) + 1
        
    end_idx = raw_text.find(end_pattern)
    if end_idx == -1: end_idx = len(raw_text)
    
    core_content = raw_text[start_idx:end_idx]
    
    # 2. HTML 标签智能转化 (炸开结构)
    text = html.unescape(core_content)
    text = re.sub(r'</th>|</td>', ' | ', text, flags=re.I)
    text = re.sub(r'</tr>|</div>|</p>|<li>|br/?>', '\n', text, flags=re.I)
    
    # 3. 剥离残留标签 (只删标签，留文字)
    text = re.sub(r'<[^>]+>', '', text)
    
    # 4. 彻底剔除剩余链接与多余符号
    text = re.sub(r'\[.*?\]\(.*?\)', '', text)
    text = re.sub(r'https?://\S+', '', text)
    
    # 5. 行清理与去重
    lines = []
    seen = set()
    for line in text.split('\n'):
        line = line.strip()
        if not line or len(line) < 2: continue
        # 简单去重
        if line in seen: continue
        
        # 剔除 Wiki 边角料
        if any(k in line for k in ["编辑", "刷新", "查看历史", "WIKI功能", "最新编辑", "更新日期"]):
            continue
            
        lines.append(line)
        seen.add(line)
        
    return "\n".join(lines)

def process_archives():
    inf = r"whmx\wiki_data\markdown_archives"
    outf = r"whmx\wiki_data\sanitized"
    if not os.path.exists(outf): os.makedirs(outf)
    
    files = glob.glob(os.path.join(inf, "*.md"))
    print(f"Executing Sanitizer V3 for {len(files)} files...")
    
    success_count = 0
    for f_path in files:
        name = os.path.basename(f_path).replace(".md", "")
        try:
            with open(f_path, "rb") as f:
                raw_bytes = f.read()
                data = ""
                for enc in ['utf-8-sig', 'utf-8', 'gbk']:
                    try:
                        data = raw_bytes.decode(enc)
                        if "稀有度" in data or name in data: break
                    except: continue
                if not data: continue
                
                cleaned = deep_sanitize_v3(data, name)
                with open(os.path.join(outf, f"{name}.md"), "w", encoding="utf-8-sig") as out_f:
                    out_f.write(f"# {name}\n\n" + cleaned)
                success_count += 1
        except: pass
        
    print(f"Sanitization V3 Done: {success_count}/{len(files)}")

if __name__ == "__main__":
    process_archives()
